# Fireworks.ai — required for RAG answers (streaming LLM)
# Get your key at https://fireworks.ai
FIREWORKS_API_KEY=fw_...

# Optional: OpenAI — for cloud embeddings (text-embedding-3-small)
# User provides their own key in the Settings panel
OPENAI_API_KEY=sk-...

# Optional: Anthropic — alternative LLM provider
ANTHROPIC_API_KEY=sk-ant-...
