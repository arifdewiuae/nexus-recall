		"@types/node": "^20",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
